<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.univscheduler.controllers.LoginController"
           styleClass="login-root">

    <!-- Background -->
    <VBox alignment="CENTER" spacing="0" style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e3a5f);">

        <!-- Logo area top -->
        <Label text="🎓 UNIV-SCHEDULER" styleClass="logo-title"/>
        <Label text="Gestion Intelligente des Salles et Emplois du Temps" styleClass="logo-subtitle"/>

        <Region prefHeight="30"/>

        <!-- Login Card -->
        <VBox fx:id="loginCard" styleClass="login-card" alignment="TOP_CENTER" spacing="20">

            <Label text="Connexion" styleClass="card-title"/>
            <Label text="Accédez à votre espace universitaire" styleClass="card-subtitle"/>

            <Region prefHeight="10"/>

            <!-- Email -->
            <VBox spacing="6">
                <Label text="Adresse Email" styleClass="field-label"/>
                <TextField fx:id="emailField" promptText="admin@univ.edu" styleClass="input-field"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label text="Mot de Passe" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="input-field"/>
            </VBox>

            <!-- Error label -->
            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

            <!-- Login button -->
            <Button fx:id="loginButton" text="Se Connecter →" onAction="#handleLogin"
                    styleClass="login-btn" maxWidth="Infinity"/>

            <ProgressIndicator fx:id="loadingIndicator" prefHeight="30" prefWidth="30"/>

            <Separator/>

            <!-- Quick access -->
            <Label text="Accès rapide (démo)" styleClass="demo-label"/>
            <HBox spacing="8" alignment="CENTER">
                <Button text="Admin" onAction="#fillAdmin" styleClass="demo-btn demo-admin"/>
                <Button text="Gestionnaire" onAction="#fillGestionnaire" styleClass="demo-btn demo-gest"/>
                <Button text="Enseignant" onAction="#fillEnseignant" styleClass="demo-btn demo-ens"/>
                <Button text="Étudiant" onAction="#fillEtudiant" styleClass="demo-btn demo-etu"/>
            </HBox>

        </VBox>

        <Region prefHeight="20"/>
        <Label fx:id="versionLabel" text="v1.0" styleClass="version-label"/>

    </VBox>
</StackPane>
