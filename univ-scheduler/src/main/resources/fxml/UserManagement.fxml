<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.univscheduler.controllers.UserManagementController"
            styleClass="main-root">

    <top>
        <VBox>
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <Button text="← Retour" styleClass="back-btn" onAction="#goBack"/>
                <Label text="👥 Gestion des Utilisateurs" styleClass="topbar-title" HBox.hgrow="ALWAYS"/>
                <Label fx:id="userNameLabel" styleClass="topbar-user"/>
            </HBox>

            <HBox styleClass="filter-bar" spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="🔍 Rechercher un utilisateur..." prefWidth="260"
                           styleClass="search-field"/>
                <ComboBox fx:id="roleFilter" prefWidth="200" promptText="Tous les rôles"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalLabel" styleClass="total-label"/>
                <Button text="+ Ajouter" styleClass="primary-btn" onAction="#showAddDialog"/>
                <Button text="✏ Modifier" styleClass="secondary-btn" onAction="#showEditSelectedDialog"/>
                <Button text="🗑 Désactiver" styleClass="danger-btn" onAction="#deleteSelected"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox styleClass="content-area">
            <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="150"/>
                    <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="150"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
                    <TableColumn fx:id="colRole" text="Rôle" prefWidth="200"/>
                    <TableColumn fx:id="colActif" text="Statut" prefWidth="120"/>
                </columns>
                <placeholder>
                    <Label text="Aucun utilisateur trouvé" styleClass="table-placeholder"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>

</BorderPane>
